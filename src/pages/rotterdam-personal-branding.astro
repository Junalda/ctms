---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { IMG } from '@/lib/images';
import { CRM_SUBSCRIBE_URL } from '@/lib/booking';

const journey = [
  { n: 'Maand 1', t: 'Fundamenten', d: 'Positioneringsworkshop, contentstrategie en visuele merkidentiteit. Eerste productiedag.' },
  { n: 'Maand 2 — 3', t: 'Momentum', d: '8–12 cinematische deliverables per maand. De eerste cases van inbound beginnen binnen te komen.' },
  { n: 'Maand 4 — 6', t: 'Autoriteit', d: 'De contentbibliotheek stapelt zich nu op. Je publiek verdubbelt. Spreek- en media-aanvragen.' },
];

const fit = [
  'Een oprichter, adviseur of bestuurder in Rotterdam of de Randstad',
  'Bouwt aan een merk voor de komende 5+ jaar, niet de komende 5 posts',
  'Realiseert €250K+ omzet en klaar om te investeren in zichtbaarheid',
  'Comfortabel voor de camera (of bereid het te leren)',
];

const notFit = [
  'Virale hits boven waarde op lange termijn wil',
  'Same-day-levering op losse posts nodig heeft',
  '"Contentfabrieken" verkiest boven creatieve samenwerkingen',
  'Niet klaar is om je 6+ maanden te committeren',
];
---

<BaseLayout
  title="Personal branding Rotterdam — Word de logische keuze | Capture the Moment Solutions"
  description="Voor Rotterdamse oprichters, adviseurs en creators die een personal brand willen dat inbound oplevert — geen impressies. Aanmelden voor de retainer."
>
  <section class="relative pt-40 pb-24 bg-black overflow-hidden">
    <div class="absolute inset-0">
      <img src={IMG.branding[1]} alt="" class="w-full h-full object-cover animate-kenburns" />
      <div class="absolute inset-0 bg-gradient-to-r from-black via-black/80 to-black/30"></div>
    </div>
    <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10 grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7">
        <div class="flex items-center gap-2 mb-8">
          <Icon name="lucide:map-pin" width={14} height={14} class="text-[#D4AF37]" />
          <span class="text-[11px] tracking-[0.4em] uppercase text-[#D4AF37]">Personal branding content · Rotterdam</span>
        </div>
        <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl leading-[0.95] tracking-tight">
          Word de<br />
          <span class="italic font-light">logische keuze.</span>
        </h1>
        <p class="mt-8 text-lg md:text-xl text-white/70 font-light max-w-xl">
          Voor Rotterdamse oprichters, adviseurs en creators die een personal brand willen dat inbound oplevert — niet alleen impressies.
        </p>
      </div>

      <div class="lg:col-span-5">
        <div class="bg-zinc-950/80 backdrop-blur border border-white/10 p-8 lg:p-10">
          <div id="pb-done" class="text-center py-8 hidden">
            <div class="w-14 h-14 rounded-full border border-[#D4AF37] mx-auto flex items-center justify-center mb-6"><Icon name="lucide:check" class="text-[#D4AF37]" /></div>
            <h3 class="font-serif text-3xl mb-3">Aanmelding ontvangen.</h3>
            <p class="text-white/60 font-light">We beoordelen aanmeldingen wekelijks. Gabriel neemt binnenkort contact op.</p>
          </div>
          <div id="pb-form-wrap">
            <div class="text-[11px] tracking-[0.4em] uppercase text-[#D4AF37] mb-3">Aanmelding</div>
            <h3 class="font-serif text-3xl mb-2">Meld je aan voor de retainer.</h3>
            <p class="text-white/60 text-sm font-light mb-8">We nemen 3–4 personal brands per kwartaal aan. Korte aanmelding hieronder.</p>
            <form id="pb-form" class="space-y-5">
              <input required name="name" placeholder="Je naam" class="w-full bg-transparent border-b border-white/20 focus:border-[#D4AF37] py-3 text-sm outline-none" />
              <input required type="email" name="email" placeholder="E-mail" class="w-full bg-transparent border-b border-white/20 focus:border-[#D4AF37] py-3 text-sm outline-none" />
              <button type="submit" class="w-full mt-4 py-4 bg-[#D4AF37] text-black text-[12px] tracking-[0.2em] uppercase font-medium hover:bg-white transition-colors">Aanmelding versturen</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Wat je krijgt */}
  <section class="bg-white text-black py-32">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="max-w-2xl mb-16">
        <div class="text-[11px] tracking-[0.4em] uppercase text-[#9C7C2A] mb-6">De samenwerking</div>
        <h2 class="font-serif text-5xl md:text-6xl leading-tight">Hoe 6 maanden eruitziet.</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-12">
        {journey.map((s) => (
          <div class="border-t border-zinc-200 pt-6">
            <div class="text-[11px] tracking-[0.3em] uppercase text-[#9C7C2A] mb-3">{s.n}</div>
            <h3 class="font-serif text-3xl mb-4">{s.t}</h3>
            <p class="text-zinc-600 font-light leading-relaxed">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Voor wie */}
  <section class="bg-black py-32">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <div class="text-[11px] tracking-[0.4em] uppercase text-[#D4AF37] mb-6">Wel</div>
          <h3 class="font-serif text-4xl mb-8">Een match als je...</h3>
          <ul class="space-y-4 text-white/80 font-light">
            {fit.map((x) => (
              <li class="flex items-start gap-3"><Icon name="lucide:check" width={16} height={16} class="text-[#D4AF37] mt-1.5" />{x}</li>
            ))}
          </ul>
        </div>
        <div class="lg:border-l lg:border-white/10 lg:pl-12">
          <div class="text-[11px] tracking-[0.4em] uppercase text-white/40 mb-6">Niet</div>
          <h3 class="font-serif text-4xl mb-8">Geen match als je...</h3>
          <ul class="space-y-4 text-white/60 font-light">
            {notFit.map((x) => (
              <li class="flex items-start gap-3"><span class="text-white/30 mt-1.5">—</span>{x}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-32 overflow-hidden">
    <div class="absolute inset-0">
      <img src={IMG.branding[2]} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/85"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-serif text-5xl md:text-7xl leading-tight">Stop met posten.<br /><span class="italic font-light">Begin met bouwen.</span></h2>
      <a href="/contact" class="mt-10 inline-flex items-center gap-3 px-10 py-5 bg-[#D4AF37] text-black text-[12px] tracking-[0.2em] uppercase font-medium hover:bg-white transition-colors">
        Meld je nu aan <Icon name="lucide:arrow-up-right" width={16} height={16} />
      </a>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ CRM_SUBSCRIBE_URL }}>
  // Aanmeldformulier — POST naar het CRM en toon de bevestiging.
  const form = document.getElementById('pb-form');
  const wrap = document.getElementById('pb-form-wrap');
  const done = document.getElementById('pb-done');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const email = String(data.get('email') || '').trim();
    if (!email) return;
    try {
      await fetch(CRM_SUBSCRIBE_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          name: data.get('name'),
          source: 'rotterdam-personal-branding-landing',
          tags: ['lead', 'personal-branding', 'rotterdam', 'landing-page'],
        }),
      });
    } catch (err) { /* stil falen — UX gaat door */ }
    wrap?.classList.add('hidden');
    done?.classList.remove('hidden');
  });
</script>
