---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout
  title="404 — Pagina niet gevonden | Capture the Moment Solutions"
  description="Deze pagina haalde de eindmontage niet. Terug naar het verhaal."
>
  <section class="min-h-screen flex items-center justify-center bg-black px-6">
    <div class="text-center max-w-xl">
      <div class="text-[11px] tracking-[0.4em] uppercase text-[#D4AF37] mb-8">404 — Buiten beeld</div>
      <h1 class="font-serif text-7xl md:text-9xl mb-8">Verdwaald in<br /><span class="italic font-light">de montage.</span></h1>
      <p class="text-white/60 font-light mb-10">Deze pagina haalde de eindmontage niet. Laten we je terugbrengen naar het verhaal.</p>
      <a href="/" class="inline-flex items-center gap-3 px-8 py-4 bg-[#D4AF37] text-black text-[12px] tracking-[0.2em] uppercase font-medium hover:bg-white transition-colors">
        Terug naar home <Icon name="lucide:arrow-up-right" width={16} height={16} />
      </a>
    </div>
  </section>
</BaseLayout>
