---
import { Icon } from 'astro-icon/components';
import { navLinks } from '@/data/nav';
import { BOOKING_URL } from '@/lib/booking';

const pathname = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent"
>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10 h-20 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-9 h-9 rounded-full border border-white/30 flex items-center justify-center group-hover:border-[#D4AF37] transition-colors">
        <span class="text-white text-xs tracking-[0.2em] font-light">CM</span>
      </div>
      <div class="hidden sm:block text-white">
        <div class="text-[11px] tracking-[0.3em] uppercase font-light leading-tight">Capture the Moment</div>
        <div class="text-[9px] tracking-[0.4em] uppercase text-white/50 leading-tight">Solutions</div>
      </div>
    </a>

    <nav class="hidden lg:flex items-center gap-9">
      {navLinks.map((l) => (
        <a
          href={l.to}
          class={`text-[13px] tracking-wide font-light transition-colors ${
            pathname === l.to ? 'text-[#D4AF37]' : 'text-white/80 hover:text-white'
          }`}
        >
          {l.name}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={BOOKING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex items-center gap-2 px-5 py-2.5 border border-white/20 hover:border-[#D4AF37] hover:bg-[#D4AF37] hover:text-black text-white text-[12px] tracking-[0.15em] uppercase font-light transition-all"
      >
        Plan een gesprek
      </a>
      <button
        id="menu-toggle"
        class="lg:hidden text-white p-2"
        aria-label="Menu"
        aria-expanded="false"
      >
        <Icon name="lucide:menu" id="menu-icon-open" width={22} height={22} />
        <Icon name="lucide:x" id="menu-icon-close" width={22} height={22} class="hidden" />
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="lg:hidden bg-black/95 backdrop-blur-xl border-t border-white/5 hidden">
    <div class="px-6 py-6 flex flex-col gap-4">
      {navLinks.map((l) => (
        <a href={l.to} class="text-white/80 text-sm tracking-wide py-2 border-b border-white/5">
          {l.name}
        </a>
      ))}
      <a
        href={BOOKING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 text-center px-5 py-3 bg-[#D4AF37] text-black text-xs tracking-[0.15em] uppercase"
      >
        Plan een gesprek
      </a>
    </div>
  </div>
</header>

<script>
  // Achtergrond van de header laten verschijnen zodra er gescrold wordt.
  const header = document.getElementById('site-header');
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 24) {
      header.classList.add('bg-black/80', 'backdrop-blur-xl', 'border-b', 'border-white/5');
      header.classList.remove('bg-transparent');
    } else {
      header.classList.remove('bg-black/80', 'backdrop-blur-xl', 'border-b', 'border-white/5');
      header.classList.add('bg-transparent');
    }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobiel menu in-/uitklappen.
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });
</script>
